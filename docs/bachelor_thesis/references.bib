@article{abdelmaksoudControlStrategiesNovel2020,
  title = {Control {{Strategies}} and {{Novel Techniques}} for {{Autonomous Rotorcraft Unmanned Aerial Vehicles}}: {{A Review}}},
  shorttitle = {Control {{Strategies}} and {{Novel Techniques}} for {{Autonomous Rotorcraft Unmanned Aerial Vehicles}}},
  author = {Abdelmaksoud, Sherif I. and Mailah, Musa and Abdallah, Ayman M.},
  date = {2020},
  journaltitle = {IEEE Access},
