  url = {https://www.annualreviews.org/content/journals/10.1146/annurev-fluid-010518-040436},
  urldate = {2025-10-23},
  abstract = {The ability of some species of owl to fly in effective silence is unique among birds and provides a distinct hunting advantage, but it remains a mystery as to exactly what aspects of the owl and its flight are responsible for this dramatic noise reduction. Crucially, this mystery extends to how the flow physics may be leveraged to generate noise-reduction strategies for wider technological application. We review current knowledge of aerodynamic noise from owls, ranging from live owl noise measurements to mathematical modeling and experiments focused on how owls may disrupt the standard routes of noise generation. Specialized adaptations and foraging strategies are not uniform across all owl species: Some species may not have need for silent flight, or their evolutionary adaptations may not be effective for useful noise reduction for certain species. This hypothesis is examined using mathematical models and borne out where possible by noise measurements and morphological observations of owl feathers and wings.},
  issue = {Volume 52, 2020},
  langid = {english}
}

